{
  "info": {
    "_postman_id": "ak-products-microservice-collection",
    "name": "AK.Products API",
    "description": "AK Products Microservice - Men, Women & Kids Dress Collections",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "productId", "value": "replace-with-actual-id", "type": "string" }
  ],
  "item": [
    {
      "name": "Products - Read",
      "item": [
        {
          "name": "GET All Products (Default Paging)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET All Products (Page 2)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?page=2&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "GET Men's Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/men",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "men"]
            }
          }
        },
        {
          "name": "GET Women's Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/women",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "women"]
            }
          }
        },
        {
          "name": "GET Kids' Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/kids",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "kids"]
            }
          }
        },
        {
          "name": "GET Featured Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/featured",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "featured"]
            }
          }
        },
        {
          "name": "GET Products by Category (Shirts)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/category/Shirts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "category", "Shirts"]
            }
          }
        },
        {
          "name": "GET Products by Category (Dresses)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/category/Dresses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "category", "Dresses"]
            }
          }
        },
        {
          "name": "GET Products - Filter by Gender (Men=1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?gender=1&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "gender", "value": "1" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET Products - Filter by Gender (Women=2)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?gender=2&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "gender", "value": "2" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET Products - Search by Keyword",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?search=shirt&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "search", "value": "shirt" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET Products - Featured Filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?featured=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [{ "key": "featured", "value": "true" }]
            }
          }
        }
      ]
    },
    {
      "name": "Products - Write",
      "item": [
        {
          "name": "POST Create Product (Men)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Men's Premium Oxford Shirt\",\n  \"description\": \"A premium quality Oxford shirt for men made with 100% cotton. Perfect for formal occasions.\",\n  \"sku\": \"MEN-OXF-NEW-001\",\n  \"brand\": \"ArrowMen\",\n  \"gender\": 1,\n  \"categoryName\": \"Shirts\",\n  \"subCategoryName\": null,\n  \"price\": 1299.99,\n  \"currency\": \"USD\",\n  \"stockQuantity\": 50,\n  \"sizes\": [\"S\", \"M\", \"L\", \"XL\"],\n  \"colors\": [\"White\", \"Blue\", \"Grey\"],\n  \"material\": \"Cotton\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "POST Create Product (Women)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Women's Floral Maxi Dress\",\n  \"description\": \"Elegant floral maxi dress crafted from premium chiffon fabric. Ideal for summer occasions.\",\n  \"sku\": \"WOM-FLOR-NEW-001\",\n  \"brand\": \"Biba\",\n  \"gender\": 2,\n  \"categoryName\": \"Dresses\",\n  \"subCategoryName\": null,\n  \"price\": 2499.99,\n  \"currency\": \"USD\",\n  \"stockQuantity\": 30,\n  \"sizes\": [\"XS\", \"S\", \"M\", \"L\"],\n  \"colors\": [\"Rose Pink\", \"Ivory\"],\n  \"material\": \"Chiffon\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "POST Create Product (Kids)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kids Superhero Printed Tee\",\n  \"description\": \"Fun superhero printed t-shirt for kids. Made with soft, breathable cotton.\",\n  \"sku\": \"KID-HERO-NEW-001\",\n  \"brand\": \"H&M Kids\",\n  \"gender\": 3,\n  \"categoryName\": \"T-Shirts\",\n  \"subCategoryName\": null,\n  \"price\": 499.99,\n  \"currency\": \"USD\",\n  \"stockQuantity\": 100,\n  \"sizes\": [\"4-5Y\", \"5-6Y\", \"6-7Y\", \"7-8Y\"],\n  \"colors\": [\"Red\", \"Blue\"],\n  \"material\": \"Soft Cotton\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "PUT Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Men's Premium Oxford Shirt - Updated Edition\",\n  \"description\": \"Updated description for premium Oxford shirt with new fabric.\",\n  \"brand\": \"ArrowMen\",\n  \"price\": 1499.99,\n  \"stockQuantity\": 75,\n  \"material\": \"Egyptian Cotton\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "DELETE Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{productId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Products - Bulk Operations",
      "item": [
        {
          "name": "POST Bulk Insert Products",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"name\": \"Women's Silk Evening Dress\",\n    \"description\": \"Elegant silk evening dress for special occasions. Premium silk fabric.\",\n    \"sku\": \"WOM-SILK-BULK-001\",\n    \"brand\": \"Biba\",\n    \"gender\": 2,\n    \"categoryName\": \"Dresses\",\n    \"subCategoryName\": null,\n    \"price\": 3999.99,\n    \"currency\": \"USD\",\n    \"stockQuantity\": 20,\n    \"sizes\": [\"XS\", \"S\", \"M\", \"L\"],\n    \"colors\": [\"Burgundy\", \"Navy\"],\n    \"material\": \"Silk\"\n  },\n  {\n    \"name\": \"Kids School Uniform Shirt\",\n    \"description\": \"Durable school uniform shirt for kids. Easy care cotton blend.\",\n    \"sku\": \"KID-SCHL-BULK-001\",\n    \"brand\": \"Gini & Jony\",\n    \"gender\": 3,\n    \"categoryName\": \"School Wear\",\n    \"subCategoryName\": null,\n    \"price\": 349.99,\n    \"currency\": \"USD\",\n    \"stockQuantity\": 150,\n    \"sizes\": [\"5-6Y\", \"6-7Y\", \"7-8Y\", \"8-9Y\"],\n    \"colors\": [\"White\"],\n    \"material\": \"Cotton Blend\"\n  },\n  {\n    \"name\": \"Men's Slim Fit Chinos\",\n    \"description\": \"Classic slim fit chinos for men. Versatile and comfortable for all-day wear.\",\n    \"sku\": \"MEN-CHIN-BULK-001\",\n    \"brand\": \"Wrangler\",\n    \"gender\": 1,\n    \"categoryName\": \"Pants\",\n    \"subCategoryName\": null,\n    \"price\": 1799.99,\n    \"currency\": \"USD\",\n    \"stockQuantity\": 60,\n    \"sizes\": [\"30x32\", \"32x32\", \"34x32\", \"36x32\"],\n    \"colors\": [\"Khaki\", \"Navy\", \"Olive\"],\n    \"material\": \"Cotton Twill\"\n  }\n]",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/bulk-insert",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "bulk-insert"]
            }
          }
        },
        {
          "name": "PUT Bulk Update Products",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"id\": \"{{productId}}\",\n    \"data\": {\n      \"name\": \"Bulk Updated Product Name\",\n      \"description\": \"Updated via bulk update operation\",\n      \"brand\": \"UpdatedBrand\",\n      \"price\": 999.99,\n      \"stockQuantity\": 50,\n      \"material\": \"Premium Cotton\"\n    }\n  }\n]",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/bulk-update",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "bulk-update"]
            }
          }
        }
      ]
    }
  ]
}
