{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=AKNotificationsDb;Username=postgres;Password=postgres"
  },
  "Keycloak": {
    "Authority": "http://localhost:8090/realms/antkart",
    "Audience": "antkart-client",
    "RequireHttpsMetadata": false
  },
  "RabbitMq": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "EmailSettings": {
    "From": "noreply@antkart.com",
    "DisplayName": "AntKart",
    "Host": "smtp.mailtrap.io",
    "Port": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": ""
  },
  "NotificationSettings": {
    "RetentionDays": 90
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200"
  },
  "ServiceName": "AK.Notification.API"
}
